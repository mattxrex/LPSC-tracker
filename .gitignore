# Environment variables (API keys, email credentials — never commit)
.env

# SQLite databases (contain user data and processing history)
*.db

# Downloaded PDFs (temporary, cleaned up after processing)
lpsc_monitor/data/bulletins/
lpsc_monitor/data/documents/
lpsc_monitor/data/agendas/
lpsc_alerts/data/bulletins/

# Runtime logs and state (regenerated on each run)
lpsc_monitor/data/*.log
lpsc_alerts/data/*.log
lpsc_monitor/data/last_success.txt
lpsc_alerts/data/last_success.txt
lpsc_monitor/data/*.html

# Personal custom keywords (local config, like .env)
lpsc_monitor/data/custom_keywords.json

# Virtual environment
lpsc_monitor/venv/

# OS
.DS_Store
