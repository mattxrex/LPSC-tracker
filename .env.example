# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Anthropic API key for document summarization (Claude Haiku)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Email settings for report delivery
# Set up: Enable 2FA on Gmail, then create an App Password at
# https://myaccount.google.com/apppasswords
EMAIL_SENDER=
EMAIL_APP_PASSWORD=
EMAIL_RECIPIENTS=
